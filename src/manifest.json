{
    "manifest_version": 3,
    "name": "GeoVitals - Country Stats on Hover",
    "version": "1.1.0",
    "description": "Hover over any country name to instantly see Demographics information, COVID-19 stats and WHO disease outbreak alerts.",
    "icons": {
        "16": "16.png",
        "32": "32.png",
        "48": "48.png",
        "128": "128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_icon": {
            "16": "16.png",
            "32": "32.png",
            "48": "48.png",
            "128": "128.png"
        },
        "default_popup": "popup.html"
    },
    "commands": {
        "toggle-extension": {
            "suggested_key": {
                "default": "Alt+G",
                "mac": "Alt+G"
            },
            "description": "Toggle GeoVitals on or off"
        }
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "https://restcountries.com/*",
        "https://disease.sh/*",
        "https://www.who.int/*"
    ]
}