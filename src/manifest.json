{
    "manifest_version": 3,
    "name": "GeoVitals - Country Insights on Hover",
    "version": "1.1.5",
    "description": "Hover over any country name for instant demographics, visa requirements, currency rates, news, COVID stats and WHO alerts.",
    "icons": {
        "16": "16.png",
        "32": "32.png",
        "48": "48.png",
        "128": "128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "exclude_matches": [
                "https://him97kr.github.io/geoquery-dashboard/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_icon": {
            "16": "16.png",
            "32": "32.png",
            "48": "48.png",
            "128": "128.png"
        },
        "default_popup": "popup.html"
    },
    "commands": {
        "toggle-extension": {
            "suggested_key": {
                "default": "Alt+G",
                "mac": "Alt+G"
            },
            "description": "Toggle GeoVitals on or off"
        }
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "permissions": [
        "storage",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "https://disease.sh/*",
        "https://www.who.int/*",
        "https://cdn.jsdelivr.net/*",
        "https://news.google.com/*"
    ]
}